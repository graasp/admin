<Layouts.admin flash={@flash} current_scope={@current_scope}>
  <div class="flex flex-col justify-center gap-1 max-w-md m-auto pt-10">
    <h2 class="text-lg">Name: {@specs.name}</h2>

    <p class="text-sm text-neutral">Version: {@specs.version}</p>
    <p class="text-sm text-neutral">Uptime: {@specs.uptime}</p>
  </div>
</Layouts.admin>
